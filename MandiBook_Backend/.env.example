# Server
PORT=5000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/mandibook

# JWT
JWT_SECRET=mandibook_jwt_secret_key_2026_change_in_production
JWT_EXPIRES_IN=7d
OTP_HASH_SECRET=mandibook_otp_secret_key_2026_change_in_production
OTP_DEBUG_BYPASS_DELIVERY=false

# Twilio (SMS OTP for Farmers)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid

# Brevo (Email OTP for Admin/Manager)
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=your_sender_email@example.com
BREVO_SENDER_NAME=MandiBook

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3200
